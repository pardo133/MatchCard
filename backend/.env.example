PORT=5000
MONGO_URI=mongodb://localhost:27017/gotgotneed
JWT_SECRET=your_jwt_secret_here
CLIENT_URL=http://localhost:5173

# ── Email (SMTP) ──────────────────────────────────────────────
# Gmail: activa "Contraseñas de aplicación" en tu cuenta Google
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_cuenta@gmail.com
SMTP_PASS=tu_app_password_aqui

# ── Stripe ────────────────────────────────────────────────────
# Claves en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_REEMPLAZA_CON_TU_CLAVE_SECRETA
# Price ID del producto mensual (Stripe Dashboard > Productos)
STRIPE_PRICE_ID=price_1TRK_PEGA_AQUI_TU_ID_COMPLETO
# Webhook secret: se genera al crear el webhook en Stripe Dashboard
# o con: stripe listen --forward-to localhost:5000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_REEMPLAZA_CON_TU_WEBHOOK_SECRET
